# BCCC backend config. With NONE of these set, the API runs in MOCK mode
# (mints fake codes, no external calls) — good for local dev & CI.
# Set them to go live. See server/README.md.

# --- Client (build-time) ---
# Where the game calls the API. Empty = same-origin (drop page hosts /api/bccc/*).
# Set to your API origin if hosted separately, e.g. https://api.bluecollar.example
VITE_BCCC_API=

# --- Server: reward ---
BCCC_PERK=15% off + early access
BCCC_RATE_LIMIT_PER_MIN=5
# BCCC_CORS_ORIGIN=https://bluecollarcountryclub.com

# --- Klaviyo ---
KLAVIYO_API_KEY=
KLAVIYO_LIST_ID=          # the "BCCC Members" list/segment id
KLAVIYO_API_REVISION=2024-10-15

# --- Shopify: pick ONE pattern ---
# Pattern A (recommended for a drop): comma-separated pre-generated single-use codes
SHOPIFY_CODE_POOL=
# Pattern B: mint on demand via Admin API
SHOPIFY_SHOP=             # blue-collar.myshopify.com
SHOPIFY_ADMIN_TOKEN=
SHOPIFY_PRICE_RULE_ID=    # parent rule: 15% off, usage_limit 1, BCCC collection, drop-window expiry

# Public URL the "Text it to a friend" share links point at (the drop page that
# embeds the game). Defaults to the game's own origin+path when unset.
VITE_BCCC_SHARE_URL=
